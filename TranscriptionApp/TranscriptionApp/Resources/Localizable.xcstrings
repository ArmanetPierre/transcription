    "\"%@%@\"" : {
      "comment" : "A text view that shows a truncated excerpt of text from a speech contribution. The text is truncated to 100 characters with an ellipsis if it is longer than that.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "\"%1$@%2$@\""
          }
        }
      }
    },
    "%@ contributions" : {
      "comment" : "A label showing the number of contributions made by a speaker. The argument is the number of contributions for that speaker.",
      "isCommentAutoGenerated" : true
    },
    "%@ segments" : {
      "comment" : "A text showing the number of segments spoken by a particular speaker. The argument is the number of segments spoken by the speaker.",
      "isCommentAutoGenerated" : true
    },
    "%@ speakers" : {
      "comment" : "A badge displaying the number of speakers in the transcription, along with a button to expand or collapse all speaker details.",
      "isCommentAutoGenerated" : true
    },
    "%@." : {
      "comment" : "A number followed by a dot, used to style list items in a numbered list. The number is followed by a period, and then the content of the list item.",
      "isCommentAutoGenerated" : true
    },
    "%@%%" : {
      "comment" : "A label displaying the percentage of a transcription that has been completed. The argument is an integer between 0 and 100.",
      "isCommentAutoGenerated" : true
    },
    "%@x" : {
      "comment" : "A button in the audio player bar that changes the playback rate of the audio. The text inside the button shows the current playback rate, formatted to one or two decimal places.",
